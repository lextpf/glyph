# clangd configuration for glyph.
#
# Why this file exists
# --------------------
# CMakeLists.txt sets CMAKE_EXPORT_COMPILE_COMMANDS ON, but Visual Studio's
# CMake generator silently ignores it - only the Ninja and Makefile
# generators emit compile_commands.json. So if you configured with the
# default `cmake -B build`, build/ has no compile DB, clangd has no per-file
# flags, and most #includes look unresolved even though the project builds.

CompileFlags:
  CompilationDatabase: build-cdb

  Add:
    - -std=c++23
    - --target=x86_64-pc-windows-msvc
    - -fms-extensions
    - -fms-compatibility
    - -fdelayed-template-parsing
    - -Wno-microsoft-include
    - -Wno-pragma-once-outside-header
    - -Wno-unknown-attributes

    # Project defines (mirrors CMakeLists.txt + PCH.hpp)
    - -DSKYRIM_SE
    - -DWIN32_LEAN_AND_MEAN
    - -DNOMINMAX
    - -DDIRECTINPUT_VERSION=0x0800
    - -DIMGUI_DEFINE_MATH_OPERATORS

    # CommonLibSSE-NG public compile definitions (PUBLIC on the
    # CommonLibSSE target, so they propagate to glyph). Mirrors the
    # defaults from build/_deps/commonlibsse-ng-src/CMakeLists.txt and
    # the SKSE_SUPPORT_XBYAK=ON we set in glyph's CMakeLists.txt.
    - -DENABLE_SKYRIM_SE=1
    - -DENABLE_SKYRIM_AE=1
    - -DENABLE_SKYRIM_VR=1
    - -DHAS_SKYRIM_MULTI_TARGETING=1
    - -DSKSE_SUPPORT_XBYAK=1
    - -DWINVER=0x0601
    - -D_WIN32_WINNT=0x0601

    # Project sources
    - -Isrc
    - -Itests

    # Bundled SKSE64 / NetImmerse headers (NiOverride, IPluginInterface,
    # OverlayInterface, GameAPI/GameObjects/etc.)
    - -Iexternal
    - -Iexternal/skse64
    - -Iexternal/skse64_common

    # vcpkg-installed deps. The compile-db preset shares
    # build/vcpkg_installed/ with the default preset (same triplet, so
    # no second install runs).
    - -Ibuild/vcpkg_installed/x64-windows-static/include

    # CommonLibSSE-NG (fetched via FetchContent into the main build tree
    # by the default preset). Also the path ClibUtil/* resolves through.
    - -Ibuild/_deps/commonlibsse-ng-src/include
    - -Ibuild-cdb/_deps/commonlibsse-ng-src/include

  Remove:
    # MSVC-only flags clangd's GCC-style parser chokes on if a
    # compile_commands.json from cl.exe is consumed directly.
    - /EHa
    - /EHs
    - /EHsc
    - /MP
    - /MD
    - /MDd
    - /MT
    - /MTd
    - /Gd
    - /Gm-
    - /GS
    - /GR
    - /Gy
    - /Oi
    - /Ot
    - /permissive-
    - /std:*
    - /Zc*
    - /ZI
    - /Zi
    - /Z7
    - /JMC
    - /sdl
    - /diagnostics:*
    - /external:*
    - -external:*
    - /Fp*
    - /Fd*
    - /Fo*
    - /FS

Diagnostics:
  # CONTRIBUTING.md prescribes a manual include order (corresponding
  # header, project headers, third-party, std), not include-what-you-use,
  # so don't surface include-graph nits.
  UnusedIncludes: None
  MissingIncludes: None
  Suppress:
    - unknown_attribute
    - pp_including_mainfile_in_preamble

Index:
  Background: Build
  StandardLibrary: Yes

InlayHints:
  Enabled: Yes
  ParameterNames: Yes
  DeducedTypes: Yes
  Designators: Yes

Hover:
  ShowAKA: Yes

Completion:
  AllScopes: Yes
