# Build output
build/*
!build/.gitkeep
build-*/

# Generated documentation
docs/*
!docs/main.html
site/*
!site/.gitkeep

# graphify knowledge-graph output
graphify-out/

# Python
__pycache__/
*.pyc

# Font Awesome Pro is licensed per-seat and must never enter the public repo
Font Awesome*

# Runtime assets (badges, duotone, fonts, particles) are never checked in --
# they ship with the deploy package, not the repo.
assets/
